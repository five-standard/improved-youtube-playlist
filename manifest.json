{
  "manifest_version": 3,
  "name": "Youtube 외장 재생목록",
  "version": "1.0.0",
  "description": "구글 개놈들아 재생목록 UI 속도좀 개선해라;;",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*", "https://api.github.com/*", "https://gist.githubusercontent.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Youtube 외장 재생목록"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
